# Backend API base URL
VITE_API_URL=http://localhost:8000

# Zitadel OIDC config
# Set these after creating a User Agent app in the Zitadel console (http://localhost:8080/ui/console)
# Redirect URI to register in Zitadel: http://localhost:5173/auth/signinwin/zitadel
# Post-logout redirect URI:            http://localhost:5173/
VITE_ZITADEL_ISSUER=http://localhost:8080
VITE_ZITADEL_CLIENT_ID=
VITE_ZITADEL_PROJECT_RESOURCE_ID=
